# ============================================================
# VinnieBuilds API — Environment Variables
# Copy this file to .env for local development.
# Set these as Railway environment variables in production.
# ============================================================

# ── PostgreSQL ──────────────────────────────────────────────
# Railway injects this automatically when you add the PostgreSQL plugin.
# For local dev, use a local Postgres connection string.
DATABASE_URL=postgresql://user:password@localhost:5432/vinniebuilds

# ── JWT Secret ──────────────────────────────────────────────
# A long random string. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars

# ── Admin Users ─────────────────────────────────────────────
# These users are created/updated in the database on every server start.
# Change passwords here, redeploy, and they update automatically.
VINNIE_USERNAME=vinnie
VINNIE_PASSWORD=choose-a-strong-password

DEV_USERNAME=dev
DEV_PASSWORD=choose-another-strong-password

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Use your Cloudflare Pages domain + any custom domain.
# Example: https://vinniebuilds.pages.dev,https://vinniebuilds.com
ALLOWED_ORIGINS=https://vinniebuilds.pages.dev,https://vinniebuilds.com

# ── Node env ─────────────────────────────────────────────────
NODE_ENV=production
